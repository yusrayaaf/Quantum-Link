# ─── Quantum Link Server — Environment Variables ───
# Copy this file to .env and fill in values

# Server
PORT=3001
NODE_ENV=production

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d

# Database (SQLite file path)
DB_PATH=./data/quantum.db

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://alpha-01.online,https://www.alpha-01.online

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Creator Panel — initial admin credentials (used only on first run)
CREATOR_USERNAME=maynulshaon
CREATOR_PASSWORD=BadSoul@1989

# Optional: Allowed file MIME types (comma-separated)
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,audio/mpeg,audio/ogg,application/pdf,text/plain
